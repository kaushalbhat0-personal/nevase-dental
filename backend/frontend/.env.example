# Hospital Management System - Frontend Environment Variables
# Copy this file to .env and update with your actual values

# Backend API URL (required)
# For local development:
VITE_API_URL=http://localhost:8000/api/v1

# For production (Vercel + Render):
# VITE_API_URL=https://your-render-backend-url.onrender.com/api/v1

# Optional: default tenant for X-Tenant-ID (e.g. super_admin without a selected org in localStorage)
# VITE_DEV_TENANT_ID=00000000-0000-0000-0000-000000000000

# Note: All variables must be prefixed with VITE_ to be accessible in the browser
